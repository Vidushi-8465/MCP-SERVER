# PostgreSQL connection (use the same values as in DBeaver)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=postgres
DB_PASSWORD=your_password
DB_SCHEMA=public

# Auto-register all tables when MCP server starts (true/false)
AUTO_SETUP_ALL_TABLES=false

# NE (Network Engineer) data configuration
NE_SCHEMA=
NE_TABLE_PREFIX=ne
AUTO_SETUP_NE_TABLES=true
